ANTHROPIC_API_KEY=sk-ant-api03-COLOQUE-SUA-CHAVE-AQUI
LEMMON_LOG_LEVEL=INFO

# Modelo padrão usado por TODOS os agentes (a menos que sobrescrito abaixo).
# Opções: claude-opus-4-7 | claude-sonnet-4-6 | claude-haiku-4-5
LEMMON_MODELO_PADRAO=claude-sonnet-4-6

# Modelo POR AGENTE (opcional — descomente pra sobrescrever).
# Recomendação: Opus pros "pensadores" (Otto e Salles); Sonnet pros operacionais.
# Custo extra estimado: +$0.05 a +$0.15 por sessão (vs ~$1 se trocar tudo pra Opus).
# LEMMON_MODELO_OTTO=claude-opus-4-7
# LEMMON_MODELO_SALLES=claude-opus-4-7
# LEMMON_MODELO_HEITOR=claude-sonnet-4-6
# LEMMON_MODELO_SONIA=claude-sonnet-4-6
# LEMMON_MODELO_AYA=claude-sonnet-4-6
# LEMMON_MODELO_RENATA=claude-sonnet-4-6
# LEMMON_MODELO_PEDRO_ABRAHAO=claude-sonnet-4-6

# === Transcrição de áudio (T34) — OPCIONAL ===
# Para usar a feature "Falar briefing" (upload de áudio convertido em texto),
# crie uma chave em https://platform.openai.com/api-keys e descomente:
# OPENAI_API_KEY=sk-proj-COLOQUE-SUA-CHAVE-AQUI
# Sem essa chave o sistema funciona normalmente, só a transcrição fica desabilitada.
